{
  "name": "auditforge/php-version",
  "description": "PHP/Apache version of AuditForge",
  "type": "project",
  "require": {
    "php": "^8.3",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "ext-curl": "*",
    "ext-openssl": "*"
  },
  "autoload": {
    "psr-4": {
      "AuditForge\\": "src/"
    }
  },
  "scripts": {
    "start": [
      "php -S 127.0.0.1:8000 -t public"
    ],
    "lint": [
      "@php -l public/index.php"
    ]
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.3.0"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
